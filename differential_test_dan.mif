WIDTH=16;
DEPTH=2048;

ADDRESS_RADIX=HEX;
DATA_RADIX=HEX;

CONTENT BEGIN
0000: 1821; --     LOADI   &B0000000000100001  ; differential mode, CH0(+), CH1(-)
0001: 9803; --     OUT     ADC
0002: 800C; --     CALL    WAIT_DIFF
0003: 9003; --     IN      ADC
0004: 101B; --     STORE   RESULT_DIFF
0005: 800F; --     CALL    CHECK_DEAD
0006: 9804; --     OUT     HEX_UP
0007: 800D; --     CALL    HOLD
0008: 5800; --     JUMP    TEST_DIFF_CH0_CH1
0009: 0819; --     LOAD    FAIL_CONST
000A: 9804; --     OUT     HEX_UP
000B: 5809; --     JUMP    ERR_MISMATCH
000C: 1990; --     LOADI   400
000D: 0814; --     LOAD    HOLD_COUNT
000E: 1016; --     STORE   HOLD_TEMP
000F: 101A; --     STORE   CD_TEMP
0010: 2818; --     SUB     DEAD_CONST
0011: 7009; --     JZERO   ERR_MISMATCH
0012: 081A; --     LOAD    CD_TEMP
0013: 8800; --     RETURN
0014: 4E20; -- HOLD_COUNT:     DW 20000
0015: 2710; -- DELAY_COUNT:    DW 10000
0016: 0000; -- HOLD_TEMP:      DW &B0000000000000000
0017: 0000; -- DELAY_TEMP:     DW &B0000000000000000
0018: DEAD; -- DEAD_CONST:     DW &B1101111010101101  ; 0xDEAD
0019: FFFF; -- FAIL_CONST:     DW &B1111111111111111  ; 0xFFFF - shown if error test fails
001A: 0000; -- CD_TEMP:        DW &B0000000000000000
001B: 0000; -- RESULT_DIFF:    DW &B0000000000000000
[001C..07FF] : 0000; -- [empty memory]
END;
