001B: 0828; --     LOAD    DELAY_COUNT
001C: 102A; --     STORE   DELAY_TEMP
001D: 082A; --     LOAD    DELAY_TEMP
001E: 37FF; --     ADDI    -1
001F: 102A; --     STORE   DELAY_TEMP
0020: 681D; --     JPOS    DELAY_LP
0021: 8800; --     RETURN
0022: 102D; --     STORE   CD_TEMP
0023: 282B; --     SUB     DEAD_CONST
0024: 7009; --     JZERO   ERR_MISMATCH
