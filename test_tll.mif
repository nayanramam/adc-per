0026: 8800; --     RETURN
0027: 4E20; -- HOLD_COUNT:     DW 20000
0028: 2710; -- DELAY_COUNT:    DW 10000
0029: 0000; -- HOLD_TEMP:      DW &B0000000000000000
002A: 0000; -- DELAY_TEMP:     DW &B0000000000000000
002B: DEAD; -- DEAD_CONST:     DW &B1101111010101101  ; 0xDEAD
002C: DEAD; -- FAIL_CONST:     DW &B1101111010101101  ; 0xDEAD - shown if error test fails
002D: 0000; -- CD_TEMP:        DW &B0000000000000000
