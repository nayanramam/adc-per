WIDTH=16;
DEPTH=2048;

ADDRESS_RADIX=HEX;
DATA_RADIX=HEX;

CONTENT BEGIN
0000: 1800; --     LOADI   &B0000000000000000
0001: 9803; --     OUT     ADC
0002: 8007; --     CALL    WAIT_SINGLE
0003: 9003; --     IN      ADC
0004: 9804; --     OUT     HEX_UP
0005: 800B; --     CALL    DELAY
0006: 5802; --     JUMP    LIVE_DISPLAY
0007: 18C8; --     LOADI   200
0008: 37FF; --     ADDI    -1
0009: 6808; --     JPOS    WAIT_S_LP
000A: 8800; --     RETURN
000B: 0813; --     LOAD    DELAY_COUNT
000C: 1015; --     STORE   DELAY_TEMP
000D: 0815; --     LOAD    DELAY_TEMP
000E: 37FF; --     ADDI    -1
000F: 1015; --     STORE   DELAY_TEMP
0010: 680D; --     JPOS    DELAY_LP
0011: 8800; --     RETURN
0012: 4E20; -- HOLD_COUNT:     DW 20000
0013: 2710; -- DELAY_COUNT:    DW 10000
0014: 0000; -- HOLD_TEMP:      DW &B0000000000000000
0015: 0000; -- DELAY_TEMP:     DW &B0000000000000000
0016: DEAD; -- DEAD_CONST:     DW &B1101111010101101  ; 0xDEAD
0017: FFFF; -- FAIL_CONST:     DW &B1111111111111111  ; 0xFFFF - shown if error test fails
0018: 0000; -- CD_TEMP:        DW &B0000000000000000
0019: 0000; -- RESULT_SGL_CH0: DW &B0000000000000000
001A: 0000; -- RESULT_SGL_CH1: DW &B0000000000000000
001B: 0000; -- RESULT_SGL_CH7: DW &B0000000000000000
001C: 0000; -- RESULT_DIFF:    DW &B0000000000000000
001D: 0000; -- RESULT_TTL:     DW &B0000000000000000
001E: 0000; -- RESULT_ERR:     DW &B0000000000000000
[001F..07FF] : 0000; -- [empty memory]
END;
